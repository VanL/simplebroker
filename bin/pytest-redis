#!/usr/bin/env python3
"""Run Valkey-backed SimpleBroker Redis tests with automatic Docker setup."""

from __future__ import annotations

import argparse
import os
import shlex
import shutil
import socket
import subprocess
import sys
import time
import uuid
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
VALKEY_IMAGE = os.environ.get("SIMPLEBROKER_VALKEY_TEST_IMAGE", "valkey/valkey:7.2")


def _run(cmd: list[str], *, env: dict[str, str] | None = None) -> None:
    print(f"+ {shlex.join(cmd)}", flush=True)
    subprocess.run(cmd, cwd=ROOT, env=env, check=True)


def _docker_port(container_name: str) -> str | None:
    result = subprocess.run(
        ["docker", "port", container_name, "6379/tcp"],
        cwd=ROOT,
        check=False,
        capture_output=True,
        text=True,
        encoding="utf-8",
        errors="replace",
    )
    if result.returncode != 0:
        return None
    output = result.stdout.strip()
    if not output:
        return None
    return output.rsplit(":", 1)[1]


def _cleanup_container(container_name: str) -> None:
    subprocess.run(
        ["docker", "rm", "-f", container_name],
        cwd=ROOT,
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def _wait_for_valkey(container_name: str, *, timeout_seconds: float = 30.0) -> str:
    deadline = time.monotonic() + timeout_seconds
    last_error = "container did not start"
    while time.monotonic() < deadline:
        port = _docker_port(container_name)
        if port is None:
            last_error = "waiting for published port"
            time.sleep(0.5)
            continue
        try:
            with socket.create_connection(("127.0.0.1", int(port)), timeout=1.0):
                return port
        except OSError as exc:
            last_error = str(exc)
            time.sleep(0.5)
    raise RuntimeError(f"Valkey did not become ready: {last_error}")


def _start_valkey_container() -> tuple[str, str]:
    container_name = f"simplebroker-valkey-test-{os.getpid()}-{uuid.uuid4().hex[:8]}"
    _run(
        [
            "docker",
            "run",
            "--detach",
            "--rm",
            "--name",
            container_name,
            "--publish-all",
            VALKEY_IMAGE,
        ]
    )
    port = _wait_for_valkey(container_name)
    return container_name, f"redis://127.0.0.1:{port}/15"


def _uv_command(*args: str) -> list[str]:
    return [
        "uv",
        "run",
        "--extra",
        "dev",
        "--with-editable",
        ".",
        "--with-editable",
        "./extensions/simplebroker_redis[dev]",
        *args,
    ]


def _classify_targets(pytest_args: list[str]) -> tuple[list[str], list[str], bool, bool]:
    shared_args: list[str] = []
    extension_args: list[str] = []
    shared_selected = False
    extension_selected = False
    for arg in pytest_args:
        if arg.startswith("-"):
            shared_args.append(arg)
            extension_args.append(arg)
            continue
        path = arg.split("::", 1)[0]
        if path.startswith("extensions/simplebroker_redis"):
            extension_selected = True
            extension_args.append(arg)
            continue
        if path.startswith("tests"):
            shared_selected = True
            shared_args.append(arg)
            continue
        shared_args.append(arg)
        extension_args.append(arg)
    has_explicit_targets = shared_selected or extension_selected
    return (
        shared_args,
        extension_args,
        not has_explicit_targets or shared_selected,
        not has_explicit_targets or extension_selected,
    )


def _with_default_target(args: list[str], default_target: str) -> list[str]:
    if any(not arg.startswith("-") for arg in args):
        return args
    return [default_target, *args]


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Run Valkey-backed SimpleBroker Redis tests with Docker setup."
    )
    parser.add_argument(
        "--fast",
        action="store_true",
        help="Run shared non-benchmark tests plus Redis extension tests.",
    )
    parser.add_argument(
        "--keep-container",
        action="store_true",
        help="Leave the temporary Valkey container running for debugging.",
    )
    args, pytest_args = parser.parse_known_args()

    if shutil.which("docker") is None:
        print("docker is required to run Valkey-backed tests", file=sys.stderr)
        return 1
    if shutil.which("uv") is None:
        print("uv is required to run Valkey-backed tests", file=sys.stderr)
        return 1

    container_name: str | None = None
    try:
        container_name, url = _start_valkey_container()
        print(f"Valkey test URL: {url}", flush=True)

        shared_env = os.environ.copy()
        shared_env["SIMPLEBROKER_VALKEY_TEST_URL"] = url
        shared_env["BROKER_TEST_BACKEND"] = "redis"

        extension_env = os.environ.copy()
        extension_env["SIMPLEBROKER_VALKEY_TEST_URL"] = url

        shared_args, extension_args, run_shared, run_extension = _classify_targets(
            pytest_args
        )
        marker = "shared and not benchmark" if args.fast else "shared"
        if run_shared:
            _run(
                _uv_command(
                    "pytest",
                    *_with_default_target(shared_args, "tests"),
                    "-m",
                    marker,
                ),
                env=shared_env,
            )
        if run_extension:
            _run(
                _uv_command(
                    "pytest",
                    *_with_default_target(
                        extension_args,
                        "extensions/simplebroker_redis/tests",
                    ),
                    "-m",
                    "redis_only",
                ),
                env=extension_env,
            )
        return 0
    except subprocess.CalledProcessError as exc:
        return exc.returncode or 1
    except KeyboardInterrupt:
        print("Interrupted", file=sys.stderr)
        return 130
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        return 1
    finally:
        if container_name and not args.keep_container:
            _cleanup_container(container_name)


if __name__ == "__main__":
    raise SystemExit(main())
